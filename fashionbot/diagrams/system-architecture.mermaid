%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#6C5CE7', 'primaryTextColor': '#fff', 'primaryBorderColor': '#a29bfe', 'lineColor': '#74b9ff', 'secondaryColor': '#00cec9', 'tertiaryColor': '#2d3436'}}}%%

graph TB
    subgraph USER["👤 USER LAYER"]
        U[Quilee / Team]
        TG[Telegram Bot]
        U <-->|alerts, reports, commands| TG
    end

    subgraph BUS["📡 MESSAGE BUS (Telegram Group / Webhook Pipeline)"]
        direction LR
        MB[Inter-Claw Message Router]
        Q1[research → scraper queue]
        Q2[scraper → buyer queue]
        Q3[buyer → seller queue]
        Q4[status → comms queue]
    end

    subgraph COMMS["🗣️ COMMUNICATION CLAW"]
        CC[Comms Agent]
        CC1[Status Reporter]
        CC2[Report Curator]
        CC3[Inter-Claw Router]
    end

    subgraph RESEARCH["🔍 RESEARCH CLAW"]
        RC[Research Agent]
        RC1[Manual List Curator]
        RC2[Trend Scanner]
        RC3[Item Validator]
        RC4[Color/Option Confirmer]
    end

    subgraph SCRAPER["🕷️ SCRAPER CLAW"]
        SC[Scraper Agent]
        SC1[Availability Checker]
        SC2[Price Monitor]
        SC3[Screenshot Prover]
        SC4[Report Generator]
        SC5[Anti-Bot Handler]
    end

    subgraph BUYER["💰 BUYER CLAW"]
        BC[Buyer Agent]
        BC1[Checkout Automator]
        BC2[Shipping Manager]
        BC3[Payment Handler]
        BC4[Inventory DB Writer]
    end

    subgraph SELLER["📦 SELLER CLAW"]
        SL[Seller Agent]
        SL1[Poshmark Lister]
        SL2[Offer Negotiator]
        SL3[Inventory Manager]
        SL4[Address Router]
    end

    subgraph INFRA["🔧 INFRASTRUCTURE"]
        DB[(Inventory DB<br/>SQLite/Supabase)]
        S3[Screenshot Storage<br/>S3/Cloudflare R2]
        STRIPE[Stripe API]
        POSH[Poshmark API]
        SELENIUM[Selenium Grid /<br/>Playwright]
        PROXY[Proxy Rotation<br/>Bright Data/SmartProxy]
    end

    %% Main Pipeline Flow
    U -->|curated item list + links| RC
    RC -->|validated items + details| Q1
    Q1 --> SC
    SC -->|availability report + screenshots| Q2
    Q2 --> BC
    BC -->|purchased items + tracking| Q3
    Q3 --> SL
    SL -->|sold/listed status| Q4
    Q4 --> CC
    CC --> TG

    %% Infrastructure connections
    SC --> SELENIUM
    SC --> PROXY
    SC --> S3
    BC --> STRIPE
    BC --> DB
    SL --> POSH
    SL --> DB

    %% Comms monitors everything
    CC <--> MB
    RC --> Q4
    SC --> Q4
    BC --> Q4

    classDef userClass fill:#6C5CE7,stroke:#a29bfe,color:#fff
    classDef busClass fill:#0984e3,stroke:#74b9ff,color:#fff
    classDef commsClass fill:#00b894,stroke:#55efc4,color:#fff
    classDef researchClass fill:#e17055,stroke:#fab1a0,color:#fff
    classDef scraperClass fill:#fdcb6e,stroke:#ffeaa7,color:#2d3436
    classDef buyerClass fill:#d63031,stroke:#ff7675,color:#fff
    classDef sellerClass fill:#6c5ce7,stroke:#a29bfe,color:#fff
    classDef infraClass fill:#2d3436,stroke:#636e72,color:#dfe6e9
