%%{init: {'theme': 'dark'}}%%

flowchart LR
    subgraph TELEGRAM["Telegram Message Bus"]
        direction TB
        GRP[Team Group Chat<br/>Human-readable updates]
        CH1[#research-to-scraper<br/>Structured JSON payloads]
        CH2[#scraper-to-buyer<br/>Available items + proofs]
        CH3[#buyer-to-seller<br/>Purchased inventory]
        CH4[#status-updates<br/>All claws report here]
        CMD[#commands<br/>User overrides & triggers]
    end

    RC[🔍 Research] -->|item_list.json| CH1
    CH1 -->|consume| SC[🕷️ Scraper]
    SC -->|available_items.json + screenshots| CH2
    CH2 -->|consume| BC[💰 Buyer]
    BC -->|purchased_items.json| CH3
    CH3 -->|consume| SL[📦 Seller]

    RC -->|status msg| CH4
    SC -->|status msg + alerts| CH4
    BC -->|purchase confirmations| CH4
    SL -->|sale notifications| CH4
    CH4 -->|forward| GRP

    CMD -->|trigger_scrape| SC
    CMD -->|approve_purchase| BC
    CMD -->|adjust_price| SL

    CC[🗣️ Comms] <-->|monitors all channels| TELEGRAM
    CC -->|formatted reports| GRP
